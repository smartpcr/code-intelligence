  "annotations": { "list": [] },
  "description": "Implementation-plan.md Stage 8.3 -- Observability surface for the agent-memory service. Every panel target references a metric emitted by an in-tree binary (see services/agent-memory/internal/obs/metrics.go for the canonical name list). Companion alert file: deploy/alerts/agent-memory.rules.yml.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "agent.recall latency (p95 / p99) -- SLO p95<=1.5s, p99<=4s",
      "description": "Per implementation-plan.md Stage 8.3: agent_recall_duration_seconds histogram. SLO threshold line at 1.5s (p95) and 4s (p99) drawn via thresholds field.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1.5 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(agent_recall_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(agent_recall_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "B"
        }
      ]
    },
