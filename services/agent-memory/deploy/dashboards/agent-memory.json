      "type": "stat",
      "title": "Partition provision lag",
      "description": "partition_provision_lag is emitted by mgmt-api's /metrics handler (see internal/mgmtapi/partition_lag.go). The gauge reads pg_partman's tail forward-partition end per parent table on each scrape; values > 0 mean pg_partman has fallen behind the rolling forward buffer. Companion alerts: partition_provision_lag_high (> 86400s) and partition_provision_lag_missing (absent()).",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "noValue": "MISSING (mgmt-api scrape failed)",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3600 },
              { "color": "red", "value": 86400 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "max(partition_provision_lag)",
          "legendFormat": "lag",
          "refId": "A"
        }
      ]
    },
