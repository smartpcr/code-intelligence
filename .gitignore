# Root .gitignore for the code-intelligence repo.
#
# The repo currently hosts a single Go service under
# `services/agent-memory/`; if/when other services land they
# should add their own toolchain-specific globs here.

# ---------------------------------------------------------------
# Go toolchain output
# ---------------------------------------------------------------
# Test / coverage artifacts produced by `go test`.
*.test
*.out
coverage.txt
coverage.html
coverage.xml

# Profiles emitted by `go test -cpuprofile` / `-memprofile` etc.
*.prof
*.pprof
*.trace

# Vendored deps -- the service runs in module mode and pulls from
# the proxy; we never check `vendor/` into the repo.
vendor/

# Binaries built into the service tree by `go build` or by IDE
# debug sessions.
services/agent-memory/bin/
services/agent-memory/dist/
services/agent-memory/cmd/**/agent-memory
services/agent-memory/cmd/**/agent-memory.exe
services/agent-memory/cmd/**/*-linux
services/agent-memory/cmd/**/*-darwin
services/agent-memory/cmd/**/*-windows.exe
# Catch `go build ./cmd/<name>` invocations from the service
# root (which emit `services/agent-memory/<name>` /
# `services/agent-memory/<name>.exe` instead of landing under
# the cmd subdir).
services/agent-memory/*.exe
services/agent-memory/concept-promoter
services/agent-memory/consolidator
services/agent-memory/repoindexer
services/agent-memory/trace-log-pruner
services/agent-memory/span-ingestor

# Go workspace files -- the monorepo uses a single module per
# service rather than a `go.work` file.
go.work
go.work.sum

# ---------------------------------------------------------------
# Pre-commit / linter caches
# ---------------------------------------------------------------
.golangci-cache/
.pre-commit-cache/

# ---------------------------------------------------------------
# Editor / OS junk
# ---------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------
# Local environment overrides
# ---------------------------------------------------------------
.env
.env.local
*.local.env

# ---------------------------------------------------------------
# Local-stack data dirs that should never be tracked. The
# `deploy/local/` compose file ships named docker volumes, but
# devs sometimes bind-mount instead -- the patterns below catch
# both common naming conventions.
# ---------------------------------------------------------------
services/agent-memory/deploy/local/data/
services/agent-memory/deploy/local/**/_data/
